# ── Credentials & secrets (NEVER commit these) ────────────────
backend/.env
*.env
*.pem
*.key

# ── Python ────────────────────────────────────────────────────
backend/venv/
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg
.eggs/

# ── Database (contains user data & OAuth tokens) ──────────────
backend/*.db
backend/*.sqlite
backend/*.sqlite3

# ── Node / Frontend ───────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── macOS ─────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# ── IDE ───────────────────────────────────────────────────────
.vscode/settings.json
.idea/
*.swp
*.swo

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
